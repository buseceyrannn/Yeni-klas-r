@model BUSEB.Models.Product

<h2>Yeni Ürün</h2>

<form asp-action="Create"
      enctype="multipart/form-data">

    <div class="mb-3">

        <label>Ürün Adı</label>

        <input asp-for="Name"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label>Fiyat</label>

        <input asp-for="Price"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label>Stok</label>

        <input asp-for="Stock"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label>Kategori</label>

        <select asp-for="CategoryId"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
        </select>

    </div>

    <div class="mb-3">

        <label>Ürün Görseli</label>

        <input type="file"
               name="imageFile"
               class="form-control" />

    </div>

    <button class="btn btn-success">

        Kaydet

    </button>

</form>