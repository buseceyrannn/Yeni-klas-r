@{
    ViewData["Title"] = "Anasayfa";
}

<div class="container-fluid pt-4 px-4">

    <div class="row g-4 mb-4">

        <div class="col-sm-6 col-xl-6">
            <div class="p-4 rounded d-flex align-items-center justify-content-between"
                 style="background-color: #191c24 !important; border: 1px solid #2c2f38;">

                <div class="d-flex align-items-center">

                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width: 60px; height: 60px; background-color: rgba(235, 22, 22, 0.1);">

                        <span style="font-size: 24px; color: #eb1616;">📦</span>

                    </div>

                    <div>

                        <p class="mb-1 text-muted"
                           style="font-size: 14px;">

                            Toplam Ürün Sayısı

                        </p>

                        <h4 class="mb-0 text-white"
                            style="font-size: 22px; font-weight: 700;">

                            @ViewBag.TotalProducts

                        </h4>

                    </div>

                </div>

            </div>
        </div>

        <div class="col-sm-6 col-xl-6">
            <div class="p-4 rounded d-flex align-items-center justify-content-between"
                 style="background-color: #191c24 !important; border: 1px solid #2c2f38;">

                <div class="d-flex align-items-center">

                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width: 60px; height: 60px; background-color: rgba(0, 115, 230, 0.1);">

                        <span style="font-size: 24px; color: #0073e6;">🗂️</span>

                    </div>

                    <div>

                        <p class="mb-1 text-muted"
                           style="font-size: 14px;">

                            Toplam Kategori Sayısı

                        </p>

                        <h4 class="mb-0 text-white"
                            style="font-size: 22px; font-weight: 700;">

                            @ViewBag.TotalCategories

                        </h4>

                    </div>

                </div>

            </div>
        </div>

    </div>

    <div class="row g-4">

        <div class="col-sm-12 col-xl-12">

            <div class="text-center rounded p-4"
                 style="background-color: #191c24 !important; border: 1px solid #2c2f38;">

                <div class="d-flex align-items-center justify-content-between mb-4">

                    <h6 class="mb-0 text-white">
                        Satış ve Stok Grafiği
                    </h6>

                </div>

                <div style="height: 200px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background-color: #0f1116;
                    border-radius: 5px;">

                    <span class="text-muted"
                          style="font-size: 14px;">

                        📊 Grafik verileri canlı sunucuda aktif edilecektir.

                    </span>

                </div>

            </div>

        </div>

    </div>

</div>