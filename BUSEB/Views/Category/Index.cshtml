@model List<BUSEB.Models.Category>

<h2>Kategoriler</h2>

@if (User.IsInRole("Admin"))
{
    <a href="/Category/Create"
       class="btn btn-primary mb-3">

        Yeni Kategori

    </a>
}

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Id</th>
            <th>Kategori Adı</th>

            @if (User.IsInRole("Admin"))
            {
                <th>İşlemler</th>
            }

        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Id</td>

                <td>@item.Name</td>

                @if (User.IsInRole("Admin"))
                {
                    <td>

                        <a href="/Category/Edit/@item.Id"
                           class="btn btn-warning">

                            Düzenle

                        </a>

                        <a href="/Category/Delete/@item.Id"
                           class="btn btn-danger">

                            Sil

                        </a>

                    </td>
                }

            </tr>
        }

    </tbody>

</table>